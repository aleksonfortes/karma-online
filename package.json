{
  "name": "karma-online",
  "private": true,
  "version": "0.0.0",
  "description": "A multiplayer web game",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:network": "jest src/modules/network",
    "test:environment": "jest src/modules/environment",
    "test:CI": "jest --ci --coverage"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "three": "^0.161.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@vitejs/plugin-react": "^4.2.1",
    "babel-jest": "^29.7.0",
    "concurrently": "^8.2.2",
    "javascript-obfuscator": "^4.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.0.3",
    "vite": "^4.5.2"
  }
}
