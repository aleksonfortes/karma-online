{
  "name": "karma-online",
  "private": true,
  "version": "0.0.0",
  "description": "A multiplayer web game",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:landing\" \"npm run dev:client\" \"npm run dev:server\"",
    "dev:landing": "vite landing-page",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "build": "vite build",
    "build:landing": "vite build landing-page",
    "preview": "vite preview",
    "preview:landing": "vite preview landing-page",
    "start": "NODE_ENV=production node server/index.js",
    "start:landing": "NODE_ENV=production node landing-page/serve.js",
    "deploy": "echo \"Deploying to Render via GitHub integration\"",
    "deploy:prod": "NODE_ENV=production npm run build && npm run build:landing",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:network": "jest src/modules/network",
    "test:environment": "jest src/modules/environment",
    "test:CI": "jest --ci --coverage",
    "test:integration": "jest tests/integration",
    "test:integration:client-server": "jest tests/integration/client-server",
    "test:integration:watch": "jest tests/integration --watch",
    "test:integration:coverage": "jest tests/integration --coverage --collectCoverageFrom='server/src/modules/network/**/*.js'"
  },
  "dependencies": {
    "concurrently": "^7.6.0",
    "express": "^4.18.2",
    "nodemon": "^2.0.22",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "three": "^0.161.0",
    "uuid": "^11.1.0",
    "vite": "^4.5.2",
    "@vitejs/plugin-react": "^4.2.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.9",
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.4.0",
    "babel-jest": "^29.7.0",
    "concurrently": "^8.2.2",
    "javascript-obfuscator": "^4.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.0.3"
  }
}
